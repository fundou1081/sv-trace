#!/usr/bin/env python3
"""TB Complexity Analysis CLI"""

import sys
sys.path.insert(0, 'src')

from verify.tb_analyzer.complexity import TBComplexityAnalyzer

def main():
    if len(sys.argv) < 2 or sys.argv[1] in ('-h', '--help'):
        print("Usage: sv-tb-complexity <file.sv>")
        print("Analyze TB complexity with 40+ metrics")
        sys.exit(0)
    
    filepath = sys.argv[1]
    analyzer = TBComplexityAnalyzer(filepath=filepath)
    print(analyzer.get_report())

if __name__ == '__main__':
    main()
