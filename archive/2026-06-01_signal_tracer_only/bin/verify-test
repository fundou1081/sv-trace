#!/usr/bin/env python3
"""
verify-test - 测试用例管理CLI
用法:
    verify-test add --name <name> --module <module> [--level P0|P1|P2]
    verify-test list [--module <module>] [--level <level>] [--status <status>]
    verify-test get <test_id>
    verify-test update <test_id> [--status <status>] [--owner <owner>]
    verify-test remove <test_id>
    verify-test stats
"""
import sys
import os
import argparse

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'src'))

from verify.test_manager import TestManager
from verify.test_case import TestLevel, TestStatus

def main():
    parser = argparse.ArgumentParser(description='测试用例管理工具')
    subparsers = parser.add_subparsers(dest='cmd', help='子命令')
    
    # add
    add_parser = subparsers.add_parser('add', help='添加测试用例')
    add_parser.add_argument('--name', required=True, help='测试名称')
    add_parser.add_argument('--module', required=True, help='所属模块')
    add_parser.add_argument('--level', default='P1', choices=['P0','P1','P2'], help='测试级别')
    add_parser.add_argument('--desc', '--description', dest='description', default='', help='描述')
    add_parser.add_argument('--owner', default='', help='负责人')
    add_parser.add_argument('--tags', nargs='*', default=[], help='标签')
    
    # list
    list_parser = subparsers.add_parser('list', help='列出测试用例')
    list_parser.add_argument('--module', help='模块过滤')
    list_parser.add_argument('--level', choices=['P0','P1','P2'], help='级别过滤')
    list_parser.add_argument('--status', choices=['pass','fail','blocked','not_run','skipped'], help='状态过滤')
    list_parser.add_argument('--owner', help='负责人过滤')
    
    # get
    get_parser = subparsers.add_parser('get', help='获取测试用例详情')
    get_parser.add_argument('test_id', help='测试ID')
    
    # update
    update_parser = subparsers.add_parser('update', help='更新测试用例')
    update_parser.add_argument('test_id', help='测试ID')
    update_parser.add_argument('--status', choices=['pass','fail','blocked','not_run','skipped'], help='状态')
    update_parser.add_argument('--owner', help='负责人')
    update_parser.add_argument('--level', choices=['P0','P1','P2'], help='级别')
    
    # remove
    remove_parser = subparsers.add_parser('remove', help='删除测试用例')
    remove_parser.add_argument('test_id', help='测试ID')
    
    # stats
    stats_parser = subparsers.add_parser('stats', help='统计信息')
    
    # record
    record_parser = subparsers.add_parser('record', help='记录测试结果')
    record_parser.add_argument('test_id', help='测试ID')
    record_parser.add_argument('--status', required=True, choices=['pass','fail','blocked','not_run','skipped'])
    record_parser.add_argument('--duration', type=int, default=0, help='执行时间(ms)')
    record_parser.add_argument('--seed', help='随机种子')
    record_parser.add_argument('--log', default='', help='日志')
    
    args = parser.parse_args()
    
    if not args.cmd:
        parser.print_help()
        return
    
    # 初始化管理器
    db_path = os.environ.get('VERIFY_DB_PATH', './test_db')
    tm = TestManager(db_path)
    
    if args.cmd == 'add':
        test = tm.add_test(
            name=args.name,
            module=args.module,
            level=args.level,
            description=args.description,
            owner=args.owner,
            tags=args.tags
        )
        print(f"[{test.id}] {test.name}")
        print(f"  模块: {test.module}, 级别: {test.level.value}")
    
    elif args.cmd == 'list':
        tests = tm.list_tests(
            module=args.module,
            level=args.level,
            status=args.status,
            owner=args.owner
        )
        print(f"\n测试用例列表 ({len(tests)} 个)")
        print("-" * 60)
        if not tests:
            print("  无测试用例")
        else:
            header = f"{'ID':>4} {'名称':<20} {'模块':<10} {'级别':>4} {'状态':<10}"
            print(header)
            print("-" * 60)
            for t in tests:
                print(f"{t.id:>4} {t.name[:20]:<20} {t.module:<10} {t.level.value:>4} {t.status.value:<10}")
        print()
    
    elif args.cmd == 'get':
        test = tm.get_test(args.test_id)
        if not test:
            print(f"Test {args.test_id} not found")
            return
        print(f"\n[{test.id}] {test.name}")
        print(f"  模块: {test.module}")
        print(f"  级别: {test.level.value}")
        print(f"  状态: {test.status.value}")
        print(f"  负责人: {test.owner or 'unassigned'}")
        print(f"  标签: {', '.join(test.tags) or 'none'}")
        print(f"  描述: {test.description or 'none'}")
        print(f"  运行次数: {test.run_count}")
        print()
    
    elif args.cmd == 'update':
        kwargs = {}
        if args.status:
            kwargs['status'] = args.status
        if args.owner:
            kwargs['owner'] = args.owner
        if args.level:
            kwargs['level'] = args.level
        
        if not kwargs:
            print("Please specify fields to update")
            return
        
        test = tm.update_test(args.test_id, **kwargs)
        if test:
            print(f"Updated {args.test_id}: status={test.status.value}, owner={test.owner}")
        else:
            print(f"Test {args.test_id} not found")
    
    elif args.cmd == 'remove':
        if tm.remove_test(args.test_id):
            print(f"Removed {args.test_id}")
        else:
            print(f"Test {args.test_id} not found")
    
    elif args.cmd == 'stats':
        stats = tm.get_stats()
        print(f"\nStatistics:")
        print(f"  Total tests: {stats['total_tests']}")
        print(f"  Total suites: {stats['total_suites']}")
        print(f"\nBy status: {stats['status_counts']}")
        print(f"By level: {stats['level_counts']}")
        print(f"By module: {stats['module_counts']}")
        print()
    
    elif args.cmd == 'record':
        result = tm.record_result(
            test_id=args.test_id,
            status=args.status,
            duration_ms=args.duration,
            seed=args.seed,
            log=args.log
        )
        print(f"Result recorded for {result.test_id}: {result.status.value} ({result.duration_ms}ms)")

if __name__ == '__main__':
    main()
