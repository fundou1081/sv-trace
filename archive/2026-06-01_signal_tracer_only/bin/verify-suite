#!/usr/bin/env python3
"""
verify-suite - 测试套件管理CLI
用法:
    verify-suite create --name <name> [--tests <ids>]
    verify-suite list
    verify-suite get <suite_id>
    verify-suite add-test <suite_id> <test_id>
    verify-suite remove-test <suite_id> <test_id>
    verify-suite remove <suite_id>
"""
import sys
import os
import argparse

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'src'))

from verify.test_manager import TestManager

def main():
    parser = argparse.ArgumentParser(description='测试套件管理工具')
    subparsers = parser.add_subparsers(dest='cmd', help='子命令')
    
    # create
    create_parser = subparsers.add_parser('create', help='创建测试套件')
    create_parser.add_argument('--name', required=True, help='套件名称')
    create_parser.add_argument('--tests', help='测试ID列表 (逗号分隔)')
    create_parser.add_argument('--desc', '--description', dest='description', default='', help='描述')
    
    # list
    subparsers.add_parser('list', help='列出测试套件')
    
    # get
    get_parser = subparsers.add_parser('get', help='获取测试套件详情')
    get_parser.add_argument('suite_id', help='套件ID')
    
    # add-test
    add_parser = subparsers.add_parser('add-test', help='添加测试到套件')
    add_parser.add_argument('suite_id', help='套件ID')
    add_parser.add_argument('test_id', help='测试ID')
    
    # remove-test
    remove_parser = subparsers.add_parser('remove-test', help='从套件移除测试')
    remove_parser.add_argument('suite_id', help='套件ID')
    remove_parser.add_argument('test_id', help='测试ID')
    
    # remove
    remove_parser = subparsers.add_parser('remove', help='删除测试套件')
    remove_parser.add_argument('suite_id', help='套件ID')
    
    args = parser.parse_args()
    
    if not args.cmd:
        parser.print_help()
        return
    
    # 初始化管理器
    db_path = os.environ.get('VERIFY_DB_PATH', './test_db')
    tm = TestManager(db_path)
    
    if args.cmd == 'create':
        test_ids = args.tests.split(',') if args.tests else []
        suite = tm.create_suite(
            name=args.name,
            test_ids=test_ids,
            description=args.description
        )
        print(f"[{suite.id}] {suite.name}")
        print(f"  Tests: {len(suite.test_ids)}")
    
    elif args.cmd == 'list':
        suites = tm.list_suites()
        print(f"\n测试套件列表 ({len(suites)} 个)")
        print("-" * 60)
        if not suites:
            print("  无测试套件")
        else:
            for s in suites:
                print(f"{s.id:>4} {s.name:<20} ({len(s.test_ids)} tests)")
        print()
    
    elif args.cmd == 'get':
        suite = tm.get_suite(args.suite_id)
        if not suite:
            print(f"Suite {args.suite_id} not found")
            return
        
        print(f"\n[{suite.id}] {suite.name}")
        print(f"  描述: {suite.description or 'none'}")
        print(f"  测试 ({len(suite.test_ids)}):")
        for tid in suite.test_ids:
            test = tm.get_test(tid)
            if test:
                print(f"    - [{tid}] {test.name} ({test.module})")
        print()
    
    elif args.cmd == 'add-test':
        if tm.add_test_to_suite(args.suite_id, args.test_id):
            print(f"Added test {args.test_id} to suite {args.suite_id}")
        else:
            print(f"Suite {args.suite_id} not found")
    
    elif args.cmd == 'remove-test':
        if tm.remove_test_from_suite(args.suite_id, args.test_id):
            print(f"Removed test {args.test_id} from suite {args.suite_id}")
        else:
            print(f"Suite {args.suite_id} not found")
    
    elif args.cmd == 'remove':
        if tm.remove_suite(args.suite_id):
            print(f"Removed suite {args.suite_id}")
        else:
            print(f"Suite {args.suite_id} not found")

if __name__ == '__main__':
    main()
